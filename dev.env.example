# Local development environment for the PRMS HTTP server.
#
# Usage (one-liner):
#   env $(grep -v '^#' dev.env | xargs) cargo run --features http --bin serve -- --enable-reset
#
# Or source it:
#   set -a; source dev.env; set +a
#   cargo run --features http --bin serve -- --enable-reset
#
# Tokens use the demo format: token == actor-id (so the web UI can
# use the entity ID directly as the bearer token).

# Crew leads and passengers from the seeded demo world.
PRMS_API_KEYS="cl-aria:cl-aria,ps-001:ps-001,ps-002:ps-002,ps-003:ps-003"

# Disable rate limiting locally — all requests come from 127.0.0.1.
PRMS_ENABLE_RATE_LIMIT=false

# Accept requests from the Vite dev server.
PRMS_CORS_ORIGINS="http://localhost:5173"

# Verbose SQL / trace logs (optional — uncomment if you need them).
# RUST_LOG="passenger_resource_management=debug,tower_http=debug"
