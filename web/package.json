{
  "name": "prms-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Thin-client frontend for the Spaceship X26 Passenger Resource Management System. All content is fetched from the Rust axum backend.",
  "scripts": {
    "dev": "vite",
    "generate:types": "openapi-typescript http://127.0.0.1:8080/openapi.json -o src/services/openapi.generated.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2"
  },
  "engines": {
    "node": ">=24"
  }
}
