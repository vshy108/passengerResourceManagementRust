{
  "name": "prms-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser demo for the Spaceship X26 Passenger Resource Management System. Mirrors the Rust specs in TypeScript so every feature is exercised end-to-end without a backend.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
