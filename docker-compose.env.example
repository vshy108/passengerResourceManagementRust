# Copy to .env and fill in values before running docker compose.

# Bearer tokens for API authentication — comma-separated token:actor-id pairs.
PRMS_API_KEYS=changeme:cl-admin

# CORS origin allowlist — must be the exact HTTPS origin of your frontend.
PRMS_CORS_ORIGINS=https://your.domain

# Public hostname for Caddy TLS (must be DNS-resolvable).
PRMS_DOMAIN=your.domain
